# Production proxy endpoints used by the static webOS build.
VITE_MEDIA_PROXY_URL=https://proxy.example.com/media-proxy
VITE_METADATA_PROXY_URL=https://proxy.example.com/media-metadata

# Standalone proxy server options.
PORT=8787
PROXY_ALLOW_ORIGIN=*
# Optional comma-separated host allowlist, e.g. example.com,cdn.example.net
ALLOWED_MEDIA_HOSTS=
