{
  "name": "webos-radio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "package:webos": "npm run build && ares-package dist",
    "preview": "vite preview --host 0.0.0.0",
    "proxy": "tsx server/index.ts",
    "serve": "tsx server/index.ts",
    "start": "npm run build && npm run serve"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "tailwindcss": "^4.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3",
    "vite": "^6.3.0"
  }
}
